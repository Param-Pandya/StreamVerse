{
  "expo": {
    "name": "StreamVerse",
    "description": "StreamVerse Streaming Application",
    "scheme": "streamverse",
    "slug": "streamverse",
    "version": "0.0.1",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "orientation": "portrait",
    "primaryColor": "#0b090f",
    "icon": "src/assets/icon.png",
    "splash": {
      "backgroundColor": "#0b090f",
      "image": "src/assets/splash.png",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "src/assets/adaptive-icon.png",
        "backgroundColor": "#0b090f"
      }
    },
    "ios": {
      "buildNumber": "0.0.1",
      "supportsTablet": true
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
